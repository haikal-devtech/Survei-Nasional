# Salin file ini jadi .env.local dan isi nilainya

# NextAuth — generate NEXTAUTH_SECRET dengan: openssl rand -base64 32
NEXTAUTH_SECRET=ganti-dengan-random-string-min-32-karakter
NEXTAUTH_URL=http://localhost:3000

# URL deployment Google Apps Script
# Dapatkan dari: Apps Script → Deploy → Manage Deployments → Copy URL
APPS_SCRIPT_URL=https://script.google.com/macros/s/GANTI_DENGAN_DEPLOYMENT_ID/exec

# Kredensial surveyor (ganti dengan yang aman)
SURVEYOR_USERNAME=admin
SURVEYOR_PASSWORD=ganti-dengan-password-aman
